# Copy this file to ".env" and fill in real values. NEVER commit .env.
# Load it before running:  (mac/linux)  export $(grep -v '^#' .env | xargs)

# --- CJ Dropshipping ---
# Get this from CJ dashboard -> Account -> API. Format: CJUserNum@api@xxxxxxxx
CJ_API_KEY=CJ0000000@api@xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe ---
# Dashboard -> Developers -> API keys. Use sk_test_ while building.
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# Restrict the backend to your real storefront domain in production.
STOREFRONT_ORIGIN=http://localhost:5500

# Port the order server listens on.
PORT=8000
